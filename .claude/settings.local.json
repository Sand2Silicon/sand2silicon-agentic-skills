{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [
    "github"
  ],
  "outputStyle": "default",
  "permissions": {
    "allow": [
      "Bash(bd: *)",
      "Bash(cd:*)",
      "Bash(chmod:*)",
      "Bash(claude --version)",
      "Bash(code --list-extensions)",
      "Bash(curl -s \"https://api.github.com/repos/dolthub/dolt/releases/latest\")",
      "Bash(curl -s \"https://api.github.com/repos/steveyegge/beads/releases/latest\")",
      "Bash(curl -sI \"https://claude.ai/install.sh\")",
      "Bash(curl -sI \"https://github.com/dolthub/dolt/releases/download/*\")",
      "Bash(curl -sI \"https://github.com/dolthub/dolt/releases/download/*\")",
      "Bash(curl -sI \"https://github.com/steveyegge/beads/releases/download/*\")",
      "Bash(docker --version)",
      "Bash(echo EXIT=$?)",
      "Bash(echo:*)",
      "Bash(env)",
      "Bash(find ~/source/*)",
      "Bash(gh api:*:--method GET)",
      "Bash(git worktree:*)",
      "Bash(npm --version)",
      "Bash(npm list:*)",
      "Bash(npm view:*)",
      "Bash(nvidia-smi)",
      "Bash(nvm --version)",
      "Bash(openspec --version)",
      "Bash(pip3 list:*)",
      "Bash(uv --version)",
      "Bash(uv tool:*)",
      "Bash(wc:*)",
      "Bash(xargs cat:*)",
      "mcp__github__get_file_contents",
      "mcp__github__search_code",
      "mcp__github__search_repositories",
      "Read(~/.claude/**)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:beads.dev)",
      "WebFetch(domain:beadsinit.dev)",
      "WebFetch(domain:containers.dev)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.astral.sh)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:marketplace.visualstudio.com)",
      "WebFetch(domain:openspec.dev)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:www.atlassian.com)",
      "WebFetch(domain:www.google.com)",
      "WebFetch(domain:www.npmjs.com)"
    ]
  }
}
