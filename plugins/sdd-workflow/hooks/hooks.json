{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/on-bd-close.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/sync-openspec-tasks.py"
      }
    ]
  }
}
