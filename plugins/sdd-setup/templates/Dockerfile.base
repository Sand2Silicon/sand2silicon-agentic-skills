# syntax=docker/dockerfile:1
# ============================================================================
# Base Devcontainer Dockerfile — AI-Driven Development Environment
# ============================================================================
# This template provides the base image for devcontainers. It installs only
# system-level packages. User-space tools (Claude Code, Beads, OpenSpec)
# are installed at runtime by setup.sh (postCreateCommand).
#
# BuildKit syntax header (line 1) is required for --mount=type=cache.
# ============================================================================

# CONFIGURE: Choose base image
# - Standard:   ubuntu:22.04 (apt-get)
# - AWS/RHEL:   amazonlinux:2023 (yum)
# - GPU/CUDA:   nvidia/cuda:12.1.0-runtime-ubuntu22.04 (apt-get)
ARG BASE_IMAGE=ubuntu:22.04
FROM ${BASE_IMAGE} AS base

# ============================================================================
# CONFIGURE: Uncomment ONE of these package-install blocks
# ============================================================================

# --- apt-based (Ubuntu, Debian, CUDA) ---
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    sudo \
    wget \
    unzip \
    jq \
    tar \
    findutils \
    openssh-client \
    less \
    && rm -rf /var/lib/apt/lists/*

# --- yum-based (Amazon Linux, RHEL) ---
# RUN yum install -y \
#     git \
#     curl \
#     vim \
#     tar \
#     findutils \
#     jq \
#     && yum clean all \
#     && rm -rf /var/cache/yum /tmp/*

# ============================================================================
# uv — Fast Python package manager (system-wide)
# ============================================================================
# UV_INSTALL_DIR puts the binary somewhere accessible to all users,
# since the installer defaults to $HOME/.local/bin (which would be root's).
RUN export UV_INSTALL_DIR=/usr/local/bin && curl -LsSf https://astral.sh/uv/install.sh | sh

# ============================================================================
# OPTIONAL: Node.js LTS (required for OpenSpec)
# ============================================================================
# NodeSource provides up-to-date Node.js. Do NOT use distro default.
# Pick the right script for your base image:
#   apt-based: deb.nodesource.com
#   yum-based: rpm.nodesource.com
ARG NODE_MAJOR=22
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*
# yum alternative:
# RUN curl -fsSL https://rpm.nodesource.com/setup_${NODE_MAJOR}.x | bash - \
#     && yum install -y nodejs && yum clean all

# ============================================================================
# OPTIONAL: Language-specific system packages
# ============================================================================
# CONFIGURE: Add packages for your primary language here.
# Python:  python3 python3-venv python3-pip (or just use uv)
# C++:     build-essential cmake gdb
# Go:      golang-go (or install from golang.org)
# Rust:    (install via rustup in setup.sh)

# ============================================================================
# Non-root user setup
# ============================================================================
ARG USERNAME=appuser
ARG USER_UID=1000
ARG USER_GID=${USER_UID}

# Handle case where group/user already exists (common for NVidia base images)
RUN groupadd -f -g ${USER_GID} ${USERNAME} || true \
    && if id -u ${USER_UID} >/dev/null 2>&1; then \
        existing_user=$(id -un ${USER_UID}) && \
        if [ "$existing_user" != "${USERNAME}" ]; then \
            usermod -l ${USERNAME} $existing_user && \
            groupmod -n ${USERNAME} $(id -gn ${USER_UID}) 2>/dev/null || true; \
        fi; \
    else \
        useradd -m -u ${USER_UID} -g ${USER_GID} -s /bin/bash ${USERNAME}; \
    fi \
    && echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/${USERNAME} \
    && chmod 0440 /etc/sudoers.d/${USERNAME} \
    && mkdir -p /workspaces \
    && chown -R ${USERNAME}:${USERNAME} /workspaces

# Ensure ~/.local/bin is on PATH (Claude Code CLI installs here via postCreateCommand)
ENV PATH="/home/${USERNAME}/.local/bin:${PATH}"

WORKDIR /workspaces
CMD ["/bin/bash"]

# ============================================================================
# Devcontainer stage
# ============================================================================
# The devcontainer stage skips adding code/models — those are bind-mounted.
# Stage name MUST be lowercase (devcontainer spec requirement).
FROM base AS devcontainer
ARG USERNAME=appuser

USER ${USERNAME}

# NOTE: User-space tools are installed by setup.sh (postCreateCommand):
#   Claude Code CLI → ~/.local/bin/claude
#   Dolt            → ~/.local/bin/dolt
#   Beads (bd)      → ~/.local/bin/bd
#   OpenSpec        → ~/.npm-global/bin/openspec
